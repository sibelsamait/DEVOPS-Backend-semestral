{
  "family": "task-despachos",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "$EXEC_ROLE_ARN",
  "taskRoleArn": "$TASK_ROLE_ARN",
  "containerDefinitions": [{
    "name": "contenedor-despachos",
    "image": "PLACEHOLDER",
    "portMappings": [{"containerPort": 8081, "protocol": "tcp"}],
    "essential": true,
    "environment": [
      {"name": "SERVER_PORT", "value": "8081"},
      {"name": "DB_ENDPOINT", "value": "$DB_ENDPOINT"},
      {"name": "DB_PORT", "value": "3306"},
      {"name": "DB_NAME", "value": "$DB_NAME"},
      {"name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://$DB_ENDPOINT:3306/$DB_NAME?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true"}
    ],
    "secrets": [
      {"name": "SPRING_DATASOURCE_USERNAME", "valueFrom": "$SECRET_ARN:username::"},
      {"name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "$SECRET_ARN:password::"},
      {"name": "DB_USERNAME", "valueFrom": "$SECRET_ARN:username::"},
      {"name": "DB_PASSWORD", "valueFrom": "$SECRET_ARN:password::"}
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {"awslogs-group": "/ecs/backend-despachos", "awslogs-region": "us-east-2", "awslogs-stream-prefix": "ecs"}
    }
  }]
}
